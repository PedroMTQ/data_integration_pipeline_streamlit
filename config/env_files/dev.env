LOG_DELAY=10
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_ACCESS_KEY=user123
S3_SECRET_ACCESS_KEY=password123
S3_HOST=localhost
S3_PORT=9000
S3_BUCKETS=data


DATA_BUCKET=data

POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"
POSTGRES_USER="fake_user"
POSTGRES_PASSWORD="fake_password"
POSTGRES_DATABASE="data_integration_pipeline"

# Elasticsearch
ELASTICSEARCH_URL="https://localhost:9200"
ELASTICSEARCH_USER="elastic"
ELASTICSEARCH_PASSWORD="elastic123"
ELASTICSEARCH_INDEX_NAME="integrated_records_v1"
ELASTICSEARCH_INDEX_ALIAS="integrated_records"
ELASTICSEARCH_NUMBER_OF_SHARDS="1"


# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=kibana123
# Version of Elastic products
STACK_VERSION=8.17.2

# Set the cluster name
CLUSTER_NAME=docker-cluster

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200

# Port to expose Kibana to the host
KIBANA_PORT=5601
#KIBANA_PORT=80

# Increase or decrease based on the available host memory (in bytes)
ES_MEM_LIMIT=4294967304

EMBEDDING_DIMENSIONS="256"
EMBEDDING_MODEL_NAME="jinaai/jina-embeddings-v5-text-nano"

# AIRFLOW
ALL_SHARED_DIRS="/opt/airflow/{logs,dags,plugins,config,app}"
AIRFLOW_UID=1000
AIRFLOW_GID=0
DEFAULT_CHUNK_SIZE="10000"